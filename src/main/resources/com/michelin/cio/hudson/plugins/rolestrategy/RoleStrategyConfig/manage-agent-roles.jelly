<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:st="jelly:stapler" xmlns:d="jelly:define"
          xmlns:l="/lib/layout" xmlns:t="/lib/hudson" xmlns:f="/lib/form" xmlns:local="local">

  <j:set var="sectionId" value="agentRoles"/>
  <j:set var="agentPermissionGroups" value="${it.strategy.descriptor.getGroups(it.strategy.SLAVE)}"/>
  <j:set var="agentGrantedRoles" value="${it.strategy.getGrantedRolesEntries(it.strategy.SLAVE)}"/>
  <j:set var="neededPermission" value="${it.strategy.AGENT_ROLES_ADMIN}"/>

  <div class="rsp-container" id="${sectionId}" data-role-type="slaveRoles" data-assign-type="slaveRoles">
    <local:appBar permissionGroups="${agentPermissionGroups}" roleType="${it.strategy.SLAVE}"
                  sectionId="${sectionId}" neededPermission="${neededPermission}"/>

    <div class="rsp-cards">
      <j:forEach var="role" items="${agentGrantedRoles}">
        <local:roleCard role="${role.key}" roleType="${it.strategy.SLAVE}"
                        showPattern="true" showTemplate="false"
                        permissionGroups="${agentPermissionGroups}"
                        neededPermission="${neededPermission}" sectionId="${sectionId}"/>
      </j:forEach>
    </div>

    <div class="jenkins-notice rsp-empty-state" hidden="true">
      <l:icon src="symbol-search" />
      ${%No matching roles}
    </div>
  </div>
</j:jelly>
