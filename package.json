{
  "name": "role-strategy-plugin",
  "version": "1.0.0",
  "description": "Role-based Authorization Strategy plugin for Jenkins",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build --mode production",
    "build:dev": "vite build --mode production --watch",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "tsc:check": "tsc",
    "biome": "biome lint .",
    "biome:fix": "biome check --write .",
    "lint": "npm run tsc:check && npm run biome",
    "test": "vitest run",
    "test:dev": "vitest watch",
    "biome:mvn": "biome lint .",
    "vitest:mvn": "vitest run --reporter default --reporter junit --outputFile \"$PWD/target/surefire-reports/vitest-junit.xml\" || ([ -n \"$CI\" ] && [ -f target/surefire-reports/vitest-junit.xml ])",
    "mvnbuild": "npm run build",
    "mvntest": "npm run format:check && npm run tsc:check && npm run biome:mvn && npm run vitest:mvn"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:jenkinsci/role-strategy-plugin.git"
  },
  "license": "MIT",
  "dependencies": {
    "@tippyjs/react": "^4.2.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-css-injected-by-js": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=23"
  }
}
